# Copy this to .env.production.local (gitignored) if you want to build
# locally against a real deployed backend. You normally won't need to -
# for the actual Coolify deployment, VITE_API_BASE_URL is set as a real
# build-time environment variable in the Coolify UI (see README.md
# "Deploying to Coolify"), which always takes priority over any .env file.
#
# .env.development already commits a safe, non-secret default
# (http://localhost:8080) for local dev - this file exists purely so
# it's obvious what env vars the app uses, not because there's a secret
# to hide.

# Base URL of the backend API the frontend talks to.
VITE_API_BASE_URL=
